{"timestamp":"00:44:05.913","source":"Browser","level":"LOG","message":"Processing controle 19, programa_controle: [{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17839,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17866,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17893,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]"}
{"timestamp":"00:44:05.913","source":"Browser","level":"LOG","message":"Processing controle 20, programa_controle: [{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17840,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17867,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17894,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]"}
