rmas de referência: IN GSI/PR nº 1/2020, art. 15, IV; NC n° 05/IN01/DSIC/GSIPR.\",\"encaminhamento_interno\":null,\"funcao_nist_csf\":null,\"grupo_imple\":null,\"id\":8,\"id_cisv8\":null,\"id_controle\":1,\"id_medida\":\"0.8\",\"justificativa\":null,\"medida\":\"O órgão instituiu Equipe de Prevenção, Tratamento e Resposta a Incidentes Cibernéticos (ETIR)?\",\"nova_resposta\":null,\"observacao_orgao\":null,\"previsao_fim\":null,\"previsao_inicio\":null,\"programa_medida\":{\"controle\":null,\"created_at\":\"2026-03-27T22:38:51.627928+00:00\",\"encaminhamento_interno\":null,\"id\":32817,\"justificativa\":null,\"medida\":8,\"nova_resposta\":null,\"observacao_orgao\":null,\"previsao_fim\":null,\"previsao_inicio\":null,\"prioridade\":false,\"programa\":49,\"responsavel\":null,\"resposta\":\"1\",\"status_medida\":null,\"status_plano_acao\":3,\"updated_at\":\"2026-03-27T22:40:58.492297+00:00\"},\"responsavel\":null,\"resposta\":\"1\",\"status_medida\":null,\"status_plano_acao\":3}]"}
