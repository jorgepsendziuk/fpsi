{"timestamp":"00:24:25.170","source":"Browser","level":"LOG","message":"Processing controle 26, programa_controle: [{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17819,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17846,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17873,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]"}
