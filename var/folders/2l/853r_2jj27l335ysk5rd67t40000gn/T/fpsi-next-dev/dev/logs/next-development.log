{"timestamp":"00:44:06.147","source":"Browser","level":"LOG","message":"Processing controle 22, programa_controle: [{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17815,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17842,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17869,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]"}
