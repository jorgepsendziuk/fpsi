{"timestamp":"00:19:17.674","source":"Browser","level":"LOG","message":"fetchControles: Full data: [{\"diagnostico\":3,\"id\":21,\"nome\":\"Registro das operações de tratamento de dados pessoais\",\"numero\":19,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17841,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17868,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17895,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]},{\"diagnostico\":3,\"id\":22,\"nome\":\"Ações de prevenção\",\"numero\":20,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17815,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17842,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17869,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]},{\"diagnostico\":3,\"id\":23,\"nome\":\"Encarregado e direitos dos titulares\",\"numero\":21,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17816,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17843,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17870,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]},{\"diagnostico\":3,\"id\":24,\"nome\":\"Contratos, acordos e instrumentos congêneres\",\"numero\":22,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17817,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17844,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17871,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]},{\"diagnostico\":3,\"id\":25,\"nome\":\"Análise das operações de tratamento\",\"numero\":23,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17818,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17845,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17872,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]},{\"diagnostico\":3,\"id\":26,\"nome\":\"Compartilhamento e transferência internacional\",\"numero\":24,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17819,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17846,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17873,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]},{\"diagnostico\":3,\"id\":27,\"nome\":\"Princípios da Lei nº 13.709/2018\",\"numero\":25,\"programa_controle\":[{\"created_at\":\"2026-03-27T22:38:49.37887+00:00\",\"id\":17820,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.37887+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.417578+00:00\",\"id\":17847,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.417578+00:00\"},{\"created_at\":\"2026-03-27T22:38:49.511231+00:00\",\"id\":17874,\"nivel\":1,\"updated_at\":\"2026-03-27T22:38:49.511231+00:00\"}]}]"}
